# Local-only credentials and source options for song suggestion imports.
# Copy this file to .env.song-sources.local. Never commit real values.

# Supabase catalog import
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional BHS published music CSV source. If neither is set, the repo-local
# data/bhs_published_music_catalog.csv file is used.
BHS_CATALOG_CSV_PATH=
BHS_CATALOG_CSV_URL=

# Optional Harmony Brigade legacy MySQL source.
HB_MYSQL_HOST=
HB_MYSQL_PORT=3306
HB_MYSQL_USER=
HB_MYSQL_PASSWORD=
HB_MYSQL_DATABASE=
HB_MYSQL_SONG_TABLE=SongData
HB_MYSQL_TITLE_COLUMN=SongTitle
HB_MYSQL_ARRANGER_COLUMN=Arranger
# Leave blank if the legacy source has no voicing column; TTBB is used by default.
HB_MYSQL_VOICING_COLUMN=
